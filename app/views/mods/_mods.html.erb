<%= turbo_frame_tag "mods" do %>
  <div class="flex flex-col flex-1 w-full">
    <div class="overflow-hidden border rounded-xl border-slate-200 dark:border-slate-700">
      <table class="w-full border-collapse table-auto">
        <thead>
          <tr class="bg-slate-100 dark:bg-slate-800">
            <th class="p-3 text-left text-sm font-semibold text-icarus-500" colspan="2">Name</th>
            <th class="hidden p-3 text-left text-sm font-semibold text-icarus-500 sm:table-cell">Author</th>
            <th class="hidden p-3 text-right text-sm font-semibold text-icarus-500 md:table-cell">Version</th>
            <th class="hidden p-3 text-center text-sm font-semibold text-icarus-500 xl:table-cell">Week</th>
            <th class="hidden p-3 text-left text-sm font-semibold text-icarus-500 lg:table-cell">Description</th>
          </tr>
        </thead>
        <tbody>
          <% if mods.empty? %>
            <tr>
              <td colspan="6" class="p-6 text-xl text-center text-icarus-500">No mods match your query</td>
            </tr>
          <% else %>
            <%= render mods %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>