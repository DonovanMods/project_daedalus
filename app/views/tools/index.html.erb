<% content_for(:title) { t('tools.title') } %>
<% content_for(:meta_description) { t('tools.meta_description') } %>

<style>
  .gold-line { height: 2px; background: linear-gradient(90deg, transparent, #f1ad1c, transparent); }
  .tool-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .tool-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.15); }
  .dark .tool-card:hover { box-shadow: 0 12px 24px rgba(0,0,0,0.4); }
</style>

<div data-controller="mods" class="max-w-screen-2xl mx-auto px-4 py-6 md:py-10">
  <%# Page Header %>
  <div class="mb-8 text-center">
    <h1 class="mb-3 text-3xl font-extrabold tracking-tight md:text-4xl lg:text-5xl text-icarus-500">
      <%= t('tools.title') %>
    </h1>
    <p class="max-w-2xl mx-auto text-base text-slate-600 dark:text-slate-400 md:text-lg">
      <%= t('tools.subtitle') %>
    </p>
    <div class="mx-auto mt-4 gold-line w-48"></div>
  </div>

  <%# Tools Grid %>
  <div class="grid gap-6 lg:grid-cols-2">
    <% @tools.each do |tool| %>
      <div id="<%= tool.slug %>"
           class="flex flex-col p-6 border-2 tool-card rounded-xl border-icarus-500 bg-gradient-to-b from-slate-100 to-white dark:from-slate-800 dark:to-slate-900">

        <%# Header: Name + Author + Download %>
        <div id="<%= tool.slug %>-header" class="flex items-start justify-between mb-4">
          <div class="flex-1">
            <h2 class="text-xl font-bold md:text-2xl text-icarus-500"><%= tool.name %></h2>
            <p class="text-sm text-blue-400"><%= t('tools.by_author', author: tool.author) %></p>
          </div>
          <div class="flex flex-col items-end flex-shrink-0 ml-4">
            <button
              data-action="mods#download"
              data-mods-url-param="<%= raw_url(tool.url) %>"
              data-mods-file-name-param="<%= tool.filename %>"
              type="button"
              class="inline-flex items-center px-4 py-2 text-sm font-medium text-white rounded-md bg-icarus-500 hover:bg-icarus-600 focus:outline-none focus:ring-2 focus:ring-icarus-400 focus:ring-offset-2">
              <%= t('tools.download') %>
            </button>
            <span class="mt-1 text-xs text-slate-500"><%= t('tools.version', version: tool.version) %></span>
          </div>
        </div>

        <%# Body: Description %>
        <div id="<%= tool.slug %>-body" class="flex-1 prose dark:prose-invert lg:prose-xl">
          <%= markdown(tool.details) %>
        </div>

        <%# Footer: Updated date %>
        <div id="<%= tool.slug %>-footer" class="pt-4 mt-4 border-t border-slate-200 dark:border-slate-700">
          <p class="text-xs text-right text-slate-500"><%= tool.updated_string %></p>
        </div>
      </div>
    <% end %>
  </div>
</div>
